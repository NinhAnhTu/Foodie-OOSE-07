@startuml
actor Admin
participant "StaffAdminController" as SAC
participant "StaffService" as SS
participant "UserRepository" as UR
participant "AuditService" as AS
participant "Database" as DB

Admin -> SAC: DELETE /admin/api/staff/delete/{id}
activate SAC

SAC -> SS: delete(id)
activate SS

SS -> UR: findById(id)
UR -> DB: SELECT * FROM users WHERE id = ?
DB --> UR: record
UR --> SS: user

SS -> UR: deleteById(id)
UR -> DB: DELETE FROM users WHERE id = ?
DB --> UR: deleted row
UR --> SS: done

SS -> AS: log(admin, "DELETE", "User", id, user, null)
activate AS
AS -> DB: INSERT INTO audit_logs
DB --> AS: log saved
AS --> SS: done
deactivate AS

SS --> SAC: success
deactivate SS

SAC -> Admin: "success" (HTTP 200)
deactivate SAC
@enduml