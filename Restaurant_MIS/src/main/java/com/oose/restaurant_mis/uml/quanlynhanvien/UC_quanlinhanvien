@startuml
left to right direction
skinparam actorStyle awesome

actor "Quản lý (Admin)" as Admin

rectangle "Quản lý nhân viên" {
  usecase "Xem danh sách nhân viên" as UC_List
  usecase "Tìm kiếm nhân viên theo tên" as UC_SearchName
  usecase "Lọc nhân viên theo chức vụ" as UC_FilterRole
  usecase "Thêm nhân viên mới" as UC_Create
  usecase "Sửa thông tin nhân viên" as UC_Update
  usecase "Xóa nhân viên" as UC_Delete
  usecase "Khóa/mở khóa tài khoản" as UC_ToggleStatus
  usecase "Phân quyền (gán role)" as UC_AssignRole
  usecase "Xem chi tiết nhân viên" as UC_ViewDetail
  usecase "Đổi mật khẩu" as UC_ResetPassword
}

Admin --> UC_List
Admin --> UC_SearchName
Admin --> UC_FilterRole
Admin --> UC_Create
Admin --> UC_Update
Admin --> UC_Delete
Admin --> UC_ToggleStatus
Admin --> UC_AssignRole
Admin --> UC_ViewDetail
Admin --> UC_ResetPassword
@enduml