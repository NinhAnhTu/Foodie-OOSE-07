@startuml
left to right direction
actor "Quản lý (Admin)" as Admin

rectangle "Quản lý danh mục món ăn" {
  usecase "Xem danh sách danh mục" as UC_List
  usecase "Tìm kiếm danh mục theo tên" as UC_Search
  usecase "Thêm danh mục mới" as UC_Create
  usecase "Sửa thông tin danh mục" as UC_Update
  usecase "Xóa danh mục" as UC_Delete
}

Admin --> UC_List
Admin --> UC_Search
Admin --> UC_Create
Admin --> UC_Update
Admin --> UC_Delete

UC_Create ..> UC_List : <<include>>
UC_Update ..> UC_List : <<include>>
UC_Delete ..> UC_List : <<include>>
@enduml